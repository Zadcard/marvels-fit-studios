# Local/preview URL used for metadata and absolute application links.
APP_URL=http://localhost:3000

# Auth.js server secret. Generate with: npx auth secret
# Secret: never expose to the browser or commit a real value.
AUTH_SECRET=replace-with-a-long-random-value

# Browser-safe Supabase project values. Prefer the publishable key name for
# new projects; ANON_KEY remains supported for existing projects.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key-if-still-used

# Server-only Supabase key used by the application repository boundary.
# Never prefix with NEXT_PUBLIC_. Never expose or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

# Optional script-only paths.
PDF_INPUT_PATH=
PDF_OUTPUT_PATH=
