// prisma/schema.prisma
// ---------------------------------------------
// Marvel Fitness Studios - Database Schema
// Version: 3.0 (Auth.js + Unified User)
// ---------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------
// USER & AUTH (Auth.js Standard)
// ---------------------------------------------

enum UserRole {
  ADMIN
  COACH
  CLIENT
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

enum TrainingSessionType {
  GROUP
  PRIVATE
}

enum TrainingSessionStatus {
  DRAFT
  SCHEDULED
  COMPLETED
  CANCELED
}

enum CoachSpecialization {
  STRENGTH
  CONDITIONING
  MOBILITY
  PRIVATE_COACHING
}

enum BookingStatus {
  BOOKED
  ATTENDED
  MISSED
  CANCELED
  WAITLIST
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAUSED
  EXPIRED
  CANCELED
}

enum BillingCycle {
  MONTHLY
  WEEKLY
  CUSTOM
}

enum ClientPaymentStatus {
  PAID
  UNPAID
  DUE_SOON
}

enum ClientLifecycleStatus {
  ACTIVE
  PENDING
  PAUSED
}

model StudioSettings {
  id                    String   @id
  studioName            String   @default("Marvel Fitness Studio")
  supportEmail          String   @default("hello@marvelfitness.studio")
  supportPhone          String   @default("+20 10 5555 9084")
  timezone              String   @default("Africa/Cairo")
  defaultSessionLength  String   @default("60 minutes")
  intakeLeadTime        String   @default("24 hours")
  overbookWaitlist      Boolean  @default(true)
  coachAutoReminders    Boolean  @default(true)
  memberCheckInAlerts   Boolean  @default(true)
  renewalDigest         Boolean  @default(false)
  cancellationWindow    String   @default("6 hours")
  privateSessionBuffer  String   @default("15 minutes")
  scheduleStartDay      String   @default("Monday")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Hashed with bcrypt
  role          UserRole  @default(CLIENT)

  // Auth.js Relations
  accounts      Account[]
  sessions      Session[]

  // Profile Relations (1-to-1)
  coachProfile  Coach?
  clientProfile Client?
  createdTrainingSessions TrainingSession[] @relation("TrainingSessionCreatedBy")
  sessionNotesAuthored    SessionNote[]

  // Admin Actions
  approvedCompensations SessionCompensation[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Lead {
  id              String     @id @default(cuid())
  fullName        String
  phone           String
  email           String?    @unique
  passwordHash    String?
  message         String?
  source          String     @default("landing-join-now")
  status          LeadStatus @default(NEW)
  consentAccepted Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------
// COACH
// ---------------------------------------------
model Coach {
  id        String   @id @default(cuid())
  fullName  String
  phone     String?
  specialization CoachSpecialization @default(STRENGTH)

  // Linked to global User account
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // One coach can manage many groups
  groups    Group[]
  trainingSessions TrainingSession[]
}

// ---------------------------------------------
// CLIENT
// ---------------------------------------------
model Client {
  id             String   @id @default(cuid())
  fullName       String
  phone          String?
  dateOfBirth    DateTime?

  // Linked to global User account
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Membership & Sessions
  membershipType String   @default("monthly")
  sessionsLeft   Int      @default(0)
  isPaid         Boolean  @default(false)
  paymentStatus  ClientPaymentStatus @default(UNPAID)
  status         ClientLifecycleStatus @default(PENDING)

  createdAt      DateTime @default(now())

  // Which group this client belongs to
  groupId        String?
  group          Group?   @relation(fields: [groupId], references: [id])

  // Relations
  payments       Payment[]
  files          File[]
  workoutNotes   WorkoutNote[]
  compensations  SessionCompensation[]
  bookings       SessionBooking[]
  subscriptions  ClientSubscription[]
}

// ---------------------------------------------
// GROUP
// ---------------------------------------------
model Group {
  id        String    @id @default(cuid())
  name      String
  type      GroupType @default(GROUP)

  createdAt DateTime  @default(now())

  // Every group must have a coach
  coachId   String
  coach     Coach     @relation(fields: [coachId], references: [id])

  // Members and files in this group
  clients   Client[]
  files     File[]
  trainingSessions TrainingSession[]
}

enum GroupType {
  GROUP    // Standard group class
  PRIVATE  // Personal training
}

// ---------------------------------------------
// PAYMENT
// ---------------------------------------------
model Payment {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("EGP")
  date      DateTime @default(now())
  note      String?

  createdAt DateTime @default(now())

  // Which client made this payment
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])

  // Optional subscription the payment belongs to
  clientSubscriptionId String?
  clientSubscription   ClientSubscription? @relation(fields: [clientSubscriptionId], references: [id], onDelete: SetNull)
}

// ---------------------------------------------
// SESSION COMPENSATION
// ---------------------------------------------
model SessionCompensation {
  id          String   @id @default(cuid())
  sessions    Int      @default(1)
  reason      String

  createdAt   DateTime @default(now())

  // Which client received the compensation
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  // Which Admin approved it
  approvedById String
  approvedBy   User     @relation(fields: [approvedById], references: [id])
}

// ---------------------------------------------
// FILE
// ---------------------------------------------
model File {
  id          String   @id @default(cuid())
  name        String
  path        String
  mimeType    String?

  createdAt   DateTime @default(now())

  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])

  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
}

// ---------------------------------------------
// WORKOUT NOTE
// ---------------------------------------------
model WorkoutNote {
  id        String   @id @default(cuid())
  content   String
  date      DateTime @default(now())

  createdAt DateTime @default(now())

  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
}

model TrainingSession {
  id          String                @id @default(cuid())
  title       String
  description String?
  type        TrainingSessionType
  status      TrainingSessionStatus @default(SCHEDULED)
  startsAt    DateTime
  endsAt      DateTime
  capacity    Int?
  location    String?
  coachId     String
  groupId     String?
  createdById String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  coach       Coach                 @relation(fields: [coachId], references: [id])
  group       Group?                @relation(fields: [groupId], references: [id])
  createdBy   User                  @relation("TrainingSessionCreatedBy", fields: [createdById], references: [id])
  bookings    SessionBooking[]
  notes       SessionNote[]

  @@index([coachId])
  @@index([groupId])
  @@index([createdById])
  @@index([startsAt])
}

model SessionBooking {
  id                String        @id @default(cuid())
  trainingSessionId String
  clientId          String
  status            BookingStatus @default(BOOKED)
  bookedAt          DateTime      @default(now())
  attendedAt        DateTime?
  canceledAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  trainingSession   TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  client            Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([trainingSessionId, clientId])
  @@index([clientId])
  @@index([status])
}

model SubscriptionPlan {
  id               String               @id @default(cuid())
  name             String
  slug             String               @unique
  description      String?
  billingCycle     BillingCycle
  sessionsIncluded Int?
  price            Float
  currency         String               @default("EGP")
  isActive         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  subscriptions    ClientSubscription[]
}

model ClientSubscription {
  id            String             @id @default(cuid())
  clientId      String
  planId        String
  status        SubscriptionStatus @default(ACTIVE)
  startsAt      DateTime
  endsAt        DateTime?
  renewsAt      DateTime?
  sessionsTotal Int?
  sessionsUsed  Int                @default(0)
  isAutoRenew   Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan   @relation(fields: [planId], references: [id])
  payments      Payment[]

  @@unique([clientId, planId])
  @@index([clientId])
  @@index([planId])
  @@index([status])
}

model SessionNote {
  id                String          @id @default(cuid())
  trainingSessionId String
  authorId          String
  content           String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  trainingSession   TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  author            User            @relation(fields: [authorId], references: [id])

  @@index([trainingSessionId])
  @@index([authorId])
}
