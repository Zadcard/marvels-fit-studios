// prisma/schema.prisma
// ════════════════════════════════════════════════════════════
// Marvel's Fit Studios — Database Schema
// Version: 2.0
// Architecture rule: Every model is self-contained and clearly
// commented. Adding new features should never break existing ones.
// ════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// SUPER ADMIN
// The hero. Full access to everything in the system.
// Can add, remove, and update any record.
// There will typically be one Super Admin account.
// ─────────────────────────────────────────────
model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Always stored as a bcrypt hash, never plain text

  createdAt DateTime @default(now())

  // Super Admin approves all session compensations
  compensations SessionCompensation[]
}

// ─────────────────────────────────────────────
// COACH
// Assigned to one or more groups.
// Can upload training files and view their clients.
// Cannot see payments or clients outside their groups.
// ─────────────────────────────────────────────
model Coach {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  phone     String?

  createdAt DateTime @default(now())

  // One coach can manage many groups
  groups    Group[]
}

// ─────────────────────────────────────────────
// CLIENT
// The studio member. Belongs to a group,
// has a session balance, payment status, and personal notes.
// ─────────────────────────────────────────────
model Client {
  id             String   @id @default(cuid())
  fullName       String
  email          String   @unique
  password       String
  phone          String?
  dateOfBirth    DateTime?

  // Membership is always "monthly" for now (12 sessions)
  // This field is kept flexible in case new types are added later
  membershipType String   @default("monthly")

  // Session balance — starts at 12 when a monthly payment is recorded
  sessionsLeft   Int      @default(0)

  // Payment status — toggled by Super Admin each month
  isPaid         Boolean  @default(false)

  createdAt      DateTime @default(now())

  // Which group this client belongs to (optional until assigned)
  groupId        String?
  group          Group?   @relation(fields: [groupId], references: [id])

  // All related records for this client
  payments       Payment[]
  files          File[]
  workoutNotes   WorkoutNote[]
  compensations  SessionCompensation[]
}

// ─────────────────────────────────────────────
// GROUP
// Links a coach to a set of clients.
// type = "group"   → 1 coach, many clients (standard class)
// type = "private" → 1 coach, 1 client (personal training)
// The type is a label only — the Super Admin controls assignments.
// ─────────────────────────────────────────────
model Group {
  id        String    @id @default(cuid())
  name      String

  // "group" or "private" — enforced by the UI/admin, not the database
  type      GroupType @default(GROUP)

  createdAt DateTime  @default(now())

  // Every group must have a coach
  coachId   String
  coach     Coach     @relation(fields: [coachId], references: [id])

  // Members and files in this group
  clients   Client[]
  files     File[]
}

// Enum = a fixed list of allowed values for the "type" field
// This is safer than a plain String — prevents typos like "gropu"
enum GroupType {
  GROUP    // Standard group class (1 coach, many clients)
  PRIVATE  // Personal training (1 coach, 1 client)
}

// ─────────────────────────────────────────────
// PAYMENT
// One payment = one monthly cycle = 12 sessions granted.
// When a payment is recorded, sessionsLeft on the Client
// should be set to 12 (handled in the backend logic, not here).
// Currency is always EGP.
// ─────────────────────────────────────────────
model Payment {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("EGP")
  date      DateTime @default(now())

  // Optional note from the Super Admin, e.g. "Paid in cash"
  note      String?

  createdAt DateTime @default(now())

  // Which client made this payment
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
}

// ─────────────────────────────────────────────
// SESSION COMPENSATION
// When a client misses a session and contacts the admin,
// the admin can restore that session. Every restoration is logged here.
// This creates a full audit trail — who got compensated, when, and why.
// ─────────────────────────────────────────────
model SessionCompensation {
  id          String   @id @default(cuid())

  // How many sessions were restored (usually 1, but flexible)
  sessions    Int      @default(1)

  // Why was this compensation approved? e.g. "Client had a family emergency"
  reason      String

  createdAt   DateTime @default(now())

  // Which client received the compensation
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])

  // Which Super Admin approved it
  approvedById String
  approvedBy   SuperAdmin @relation(fields: [approvedById], references: [id])
}

// ─────────────────────────────────────────────
// FILE
// Training files uploaded by coaches and stored locally.
// Files are linked to a group so all clients in the group can see them.
// Can also be linked directly to one specific client (optional).
// Local path stored instead of a cloud URL.
// ─────────────────────────────────────────────
model File {
  id          String   @id @default(cuid())
  name        String   // Display name, e.g. "Week 3 Plan.pdf"

  // Path relative to the /public folder, e.g. "/uploads/week3-plan.pdf"
  // Accessible in the browser at: http://localhost:3000/uploads/week3-plan.pdf
  path        String

  // MIME type for display purposes, e.g. "application/pdf"
  mimeType    String?

  createdAt   DateTime @default(now())

  // File belongs to a group (visible to all clients in that group)
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id])

  // Optionally also pinned to a specific client
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id])
}

// ─────────────────────────────────────────────
// WORKOUT NOTE
// Written by the client to log their sessions.
// Content is free text. Date is auto-saved.
// Clients can browse past notes by date.
// ─────────────────────────────────────────────
model WorkoutNote {
  id        String   @id @default(cuid())

  // The note content — e.g. "Bench press: 3x10 @ 80kg. Felt strong."
  content   String

  // The date of the workout — defaults to when the note is created
  date      DateTime @default(now())

  createdAt DateTime @default(now())

  // Which client wrote this note
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
}