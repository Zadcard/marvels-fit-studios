{
  "name": "marvels-fit-studios",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test:run && npm run build",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset --local",
    "supabase:migrations": "supabase migration list --linked",
    "supabase:lint": "supabase db lint --linked --level warning",
    "supabase:types": "supabase gen types typescript --linked --schema public > lib/supabase/database.types.ts",
    "supabase:validate": "supabase db query --linked --file supabase/verification/validate_migration.sql",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:analytics": "node tests/analytics-event-catalog.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:design-system": "node tests/dashboard-mini-stat-adoption.test.mjs",
    "promote:leads": "node scripts/promote-leads-to-clients.cjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.3",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.30",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "happy-dom": "^20.9.0",
    "pdf-parse": "^2.4.5",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
